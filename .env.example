# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Supabase project (from Settings → API in the Supabase dashboard)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Next.js browser-facing aliases. These are public by design and protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Optional migration flag. Leave unset/0 to preserve the current legacy UI exactly.
NEXT_PUBLIC_USE_REACT_SHELL=0

# service_role key — ONLY used locally by classify-inspiration skill, never in browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Server-only support vars
SUPABASE_DB_PASSWORD=
INSTALL_SKILL_SECRET=

# Server-only ClickUp token for Next API calls. Do not expose this as NEXT_PUBLIC_*.
CLICKUP_API_KEY=
